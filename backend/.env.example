# Environment Configuration for Mission Control Backend
# Copy this file to .env and update the values

# Server Configuration
PORT=3001
HOST=0.0.0.0

# CORS Origins - comma-separated list of allowed origins
# For production, include your GitHub Pages URL
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://jbtdc24.github.io

# Database Configuration
# DATA_DIR specifies where the JSON database file will be stored
# On Railway/Render, this should be a persistent volume path if available
# Default: ./data (relative to project root)
DATA_DIR=./data

# Example for Railway persistent volume:
# DATA_DIR=/data

# Example for Render:
# DATA_DIR=/var/data
